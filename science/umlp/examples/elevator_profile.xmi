<?xml version="1.0" encoding="UTF-8"?>
<uml:Profile xmi:version="2.1" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" 
             xmlns:uml="http://www.omg.org/spec/UML/20131001" 
             name="ElevatorTimingProfile">
    
    <!-- TimedAction Stereotype für Klassen mit zeitlichen Constraints -->
    <stereotype name="TimedAction" baseClass="Class">
        <ownedAttribute name="description" type="String" defaultValue=""/>
        <timingConstraint minDuration="0" maxDuration="10000" typicalDuration="3000" 
                          timeout="15000" unit="ms"/>
    </stereotype>
    
    <!-- TimedOperation Stereotype für Operationen mit Zeitangaben -->
    <stereotype name="TimedOperation" baseClass="Operation">
        <ownedAttribute name="is_blocking" type="Boolean" defaultValue="true"/>
        <timingConstraint minDuration="0" maxDuration="5000" typicalDuration="1000" 
                          timeout="10000" unit="ms"/>
    </stereotype>
    
    <!-- TimedState Stereotype für Zustände -->
    <stereotype name="TimedState" baseClass="Class">
        <ownedAttribute name="is_stable" type="Boolean" defaultValue="true"/>
        <timingConstraint minDuration="0" unit="ms"/>
    </stereotype>
    
    <!-- Entity Stereotype (aus ursprünglichem Profil) -->
    <stereotype name="Entity" baseClass="Class">
        <ownedAttribute name="tableName" type="String"/>
        <ownedAttribute name="schema" type="String" defaultValue="public"/>
    </stereotype>
    
    <!-- Column Stereotype (aus ursprünglichem Profil) -->
    <stereotype name="Column" baseClass="Property">
        <ownedAttribute name="columnName" type="String"/>
        <ownedAttribute name="nullable" type="Boolean" defaultValue="true"/>
        <ownedAttribute name="primaryKey" type="Boolean" defaultValue="false"/>
    </stereotype>
    
</uml:Profile>

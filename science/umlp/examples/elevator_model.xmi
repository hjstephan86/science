<?xml version="1.0" encoding="UTF-8"?>
<uml:Model xmi:version="2.1" xmlns:xmi="http://www.omg.org/spec/XMI/20131001" 
           xmlns:uml="http://www.omg.org/spec/UML/20131001" 
           name="ElevatorDoorModel">
    
    <!-- Aufzugstür öffnen - Hauptaktion (2.5-4.0 Sekunden) -->
    <packagedElement xmi:type="uml:Class" name="OpenDoor" stereotype="TimedAction">
        <ownedAttribute name="description" type="String"/>
        <taggedValue tag="description" value="Opening elevator door sequence"/>
        <timingConstraint minDuration="2500" maxDuration="4000" typicalDuration="3000" 
                          timeout="5000" unit="ms"/>
    </packagedElement>
    
    <!-- Tür geschlossen Zustand -->
    <packagedElement xmi:type="uml:Class" name="DoorClosed" stereotype="TimedState">
        <ownedAttribute name="is_stable" type="Boolean"/>
        <taggedValue tag="is_stable" value="true"/>
        <timingConstraint unit="ms"/>
    </packagedElement>
    
    <!-- Tür öffnet sich (Transition) (2.0-3.5 Sekunden) -->
    <packagedElement xmi:type="uml:Class" name="DoorOpening" stereotype="TimedAction">
        <ownedAttribute name="description" type="String"/>
        <taggedValue tag="description" value="Physical door opening motion"/>
        <timingConstraint minDuration="2000" maxDuration="3500" typicalDuration="2800" 
                          timeout="4000" unit="ms"/>
    </packagedElement>
    
    <!-- Tür offen Zustand (bleibt 3-10 Sekunden offen) -->
    <packagedElement xmi:type="uml:Class" name="DoorOpen" stereotype="TimedState">
        <ownedAttribute name="is_stable" type="Boolean"/>
        <taggedValue tag="is_stable" value="true"/>
        <timingConstraint minDuration="3000" maxDuration="10000" unit="ms"/>
    </packagedElement>
    
    <!-- Motor aktivieren Operation (100-500 Millisekunden) -->
    <packagedElement xmi:type="uml:Operation" name="activateMotor" stereotype="TimedOperation">
        <ownedAttribute name="is_blocking" type="Boolean"/>
        <taggedValue tag="is_blocking" value="false"/>
        <timingConstraint minDuration="100" maxDuration="500" typicalDuration="200" 
                          timeout="1000" unit="ms"/>
    </packagedElement>
    
    <!-- Sicherheitsprüfung Operation (50-200 Millisekunden, blocking) -->
    <packagedElement xmi:type="uml:Operation" name="checkSafety" stereotype="TimedOperation">
        <ownedAttribute name="is_blocking" type="Boolean"/>
        <taggedValue tag="is_blocking" value="true"/>
        <timingConstraint minDuration="50" maxDuration="200" typicalDuration="100" 
                          timeout="500" unit="ms"/>
    </packagedElement>
    
    <!-- Tür schließen (2.0-3.5 Sekunden) -->
    <packagedElement xmi:type="uml:Class" name="CloseDoor" stereotype="TimedAction">
        <ownedAttribute name="description" type="String"/>
        <taggedValue tag="description" value="Closing elevator door sequence"/>
        <timingConstraint minDuration="2000" maxDuration="3500" typicalDuration="2800" 
                          timeout="4000" unit="ms"/>
    </packagedElement>
    
    <!-- Hindernis erkannt (sofortige Reaktion, <100ms) -->
    <packagedElement xmi:type="uml:Operation" name="detectObstacle" stereotype="TimedOperation">
        <ownedAttribute name="is_blocking" type="Boolean"/>
        <taggedValue tag="is_blocking" value="true"/>
        <timingConstraint minDuration="10" maxDuration="100" typicalDuration="50" 
                          timeout="200" unit="ms"/>
    </packagedElement>
    
</uml:Model>

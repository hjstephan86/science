digraph "packages_umlp" {
rankdir=BT
charset="utf-8"
"src" [color="black", label=<src>, shape="box", style="solid"];
"src.class_generator" [color="black", label=<src.class_generator>, shape="box", style="solid"];
"src.code_generator" [color="black", label=<src.code_generator>, shape="box", style="solid"];
"src.demo_analyzer" [color="black", label=<src.demo_analyzer>, shape="box", style="solid"];
"src.experiments" [color="black", label=<src.experiments>, shape="box", style="solid"];
"src.main" [color="black", label=<src.main>, shape="box", style="solid"];
"src.markov_analyzer" [color="black", label=<src.markov_analyzer>, shape="box", style="solid"];
"src.model_parser" [color="black", label=<src.model_parser>, shape="box", style="solid"];
"src.profile_parser" [color="black", label=<src.profile_parser>, shape="box", style="solid"];
"src.queue_analyzer" [color="black", label=<src.queue_analyzer>, shape="box", style="solid"];
"src.stability_analysis" [color="black", label=<src.stability_analysis>, shape="box", style="solid"];
"src.template_generator" [color="black", label=<src.template_generator>, shape="box", style="solid"];
"src.uml_marte_stability" [color="black", label=<src.uml_marte_stability>, shape="box", style="solid"];
"src.uml_profile_base" [color="black", label=<src.uml_profile_base>, shape="box", style="solid"];
"src.class_generator" -> "src.uml_profile_base" [arrowhead="open", arrowtail="none"];
"src.code_generator" -> "src.model_parser" [arrowhead="open", arrowtail="none"];
"src.demo_analyzer" -> "src.markov_analyzer" [arrowhead="open", arrowtail="none"];
"src.demo_analyzer" -> "src.queue_analyzer" [arrowhead="open", arrowtail="none"];
"src.experiments" -> "src.stability_analysis" [arrowhead="open", arrowtail="none"];
"src.main" -> "src.class_generator" [arrowhead="open", arrowtail="none"];
"src.main" -> "src.code_generator" [arrowhead="open", arrowtail="none"];
"src.main" -> "src.model_parser" [arrowhead="open", arrowtail="none"];
"src.main" -> "src.profile_parser" [arrowhead="open", arrowtail="none"];
"src.profile_parser" -> "src.uml_profile_base" [arrowhead="open", arrowtail="none"];
}

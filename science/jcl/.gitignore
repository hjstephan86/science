# Ignore everything by default
*

# Keep the ignore file itself
!.gitignore
!MANUAL.md
!README.md

# Keep the main project source tree and relevant source files
!src/
!src/**/
!src/**/*.java
!src/**/*.xml
!src/**/*.md
!src/**/*.txt

# Keep the science subproject and its relevant source files
!science/
!science/**/
!science/**/*.java
!science/**/*.xml
!science/**/*.md
!science/**/*.py
!science/**/*.tex

# Ignore build output and IDE files
**/target/
target/
build/
.idea/
.vscode/
*.class
!HelloWorld.class
